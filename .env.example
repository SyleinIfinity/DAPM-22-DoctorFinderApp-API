SPRING_APPLICATION_NAME=backend

# PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:55432/dapm-doctor
SPRING_DATASOURCE_USERNAME=admin
SPRING_DATASOURCE_PASSWORD=

# Spring Security (basic auth)
APP_SECURITY_BASIC_USERNAME=sylein
APP_SECURITY_BASIC_PASSWORD=123456
APP_SECURITY_BASIC_ROLES=ADMIN

# Cloudinary (Images storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Gmail SMTP (OTP email)
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
# Gmail app password is often displayed with spaces (e.g. "gieo fkps stfv mlqa").
# Use the same 16 characters without spaces in env files.
SPRING_MAIL_PASSWORD=
APP_MAIL_FROM=
APP_MAIL_DISPLAY_NAME=FinderDoctor System Support

# Firebase Admin (Firestore)
FIREBASE_CREDENTIALS_PATH=secrets/firebase-service-account.json

# OTP stage (Firestore)
APP_OTP_COLLECTION=otp_stage
APP_OTP_LENGTH=6
APP_OTP_EXPIRE_SECONDS=300
APP_OTP_RESEND_COOLDOWN_SECONDS=60
APP_OTP_MAX_ATTEMPTS=5
APP_OTP_LOCK_SECONDS=900
APP_OTP_PROOF_SECRET=CHANGE_THIS_OTP_PROOF_SECRET_MIN_32_CHARS_LONG
APP_OTP_PROOF_EXPIRE_SECONDS=900

# Auth rate-limit controls
APP_SECURITY_LOGIN_MAX_FAILURES=5
APP_SECURITY_LOGIN_WINDOW_SECONDS=900
APP_SECURITY_LOGIN_BLOCK_SECONDS=900
APP_SECURITY_OTP_WINDOW_SECONDS=600
APP_SECURITY_OTP_BLOCK_SECONDS=900
APP_SECURITY_OTP_SEND_MAX_PER_IP=10
APP_SECURITY_OTP_SEND_MAX_PER_EMAIL=5
APP_SECURITY_OTP_VERIFY_MAX_PER_IP=20
APP_SECURITY_OTP_VERIFY_MAX_PER_EMAIL=10

# Gemini API (AI image search for doctors)
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_REQUEST_TIMEOUT_SECONDS=30
APP_AI_DOCTOR_IMAGE_SEARCH_MAX_CANDIDATES=30
APP_AI_DOCTOR_IMAGE_SEARCH_DEFAULT_LIMIT=5
